{"kind":"AIL-Bytecode","package":"support-ticket","version":"0.1.0","profile":"Application","capability_grants":[],"target_support":{"aarch64-apple-darwin-libsystem-macho":"planned-contract","linux-x86_64-elf":"supported","wasm32-unknown-sandbox-wasm":"supported-with-host-imports"},"external_bindings":[],"actions":[{"action":"AssignTicket","instructions":[{"opcode":"ACTION_BEGIN","operands":{"action":"AssignTicket"}},{"opcode":"REQUIRE_EXISTS","operands":{"failure":"NotFound","key":"ticket.id","rule":"the ticket to exist"}},{"opcode":"REQUIRE_FIELD_IN","operands":{"failure":"RequirementFailed","key":"ticket.status","rule":"the ticket status to be New or Open","values":"New\u001fOpen"}},{"opcode":"REQUIRE_FIELD_IN","operands":{"failure":"PermissionDenied","key":"ticket.assignee.role","rule":"the assignee role to be SupportAgent or SupportManager","values":"SupportAgent\u001fSupportManager"}},{"opcode":"WRITE_FIELD","operands":{"key":"ticket.assignee","text":"the ticket assignee"}},{"opcode":"SET_FIELD","operands":{"key":"ticket.status","text":"the status to Assigned","value":"Assigned"}},{"opcode":"EFFECT","operands":{"text":"a public update"}},{"opcode":"ASSERT_GUARANTEE","operands":{"text":"the assignee can see internal notes"}},{"opcode":"EMIT_TRACE","operands":{"event":"TicketAssigned"}},{"opcode":"RETURN_SUCCESS","operands":{}}]},{"action":"CloseTicket","instructions":[{"opcode":"ACTION_BEGIN","operands":{"action":"CloseTicket"}},{"opcode":"REQUIRE_EXISTS","operands":{"failure":"NotFound","key":"ticket.id","rule":"the ticket to exist"}},{"opcode":"REQUIRE_FIELD_NOT_EQUALS","operands":{"failure":"RequirementFailed","key":"ticket.status","rule":"the ticket status not to be Closed","value":"Closed"}},{"opcode":"SET_FIELD","operands":{"key":"ticket.status","text":"the ticket status to Closed","value":"Closed"}},{"opcode":"EFFECT","operands":{"text":"a public update"}},{"opcode":"ASSERT_GUARANTEE","operands":{"text":"closed tickets do not appear in the open ticket queue"}},{"opcode":"EMIT_TRACE","operands":{"event":"TicketClosed"}},{"opcode":"RETURN_SUCCESS","operands":{}}]},{"action":"CreateTicket","instructions":[{"opcode":"ACTION_BEGIN","operands":{"action":"CreateTicket"}},{"opcode":"REQUIRE_FIELD_IN","operands":{"failure":"PermissionDenied","key":"user.role","rule":"the caller role to be Customer","values":"Customer"}},{"opcode":"REQUIRE_EXISTS","operands":{"failure":"RequirementFailed","key":"ticket.customer.id","rule":"the customer id and title"}},{"opcode":"REQUIRE_EXISTS","operands":{"failure":"RequirementFailed","key":"ticket.title","rule":"the customer id and title"}},{"opcode":"SET_FIELD","operands":{"key":"ticket.status","text":"a Ticket with status New","value":"New"}},{"opcode":"COPY_FIELD","operands":{"key":"ticket.customer","source":"ticket.customer","text":"the customer as the ticket customer"}},{"opcode":"EFFECT","operands":{"text":"an initial public update"}},{"opcode":"ASSERT_GUARANTEE","operands":{"text":"internal notes are empty and secret"}},{"opcode":"EMIT_TRACE","operands":{"event":"TicketCreated"}},{"opcode":"RETURN_SUCCESS","operands":{}}]},{"action":"MarksOverdueTickets","instructions":[{"opcode":"ACTION_BEGIN","operands":{"action":"MarksOverdueTickets"}},{"opcode":"REQUIRE_FIELD_AFTER","operands":{"failure":"RequirementFailed","key":"ticket.due_at","rule":"the current time to be later than due_at","source":"current.time"}},{"opcode":"READ_FIELD","operands":{"key":"ticket.status","text":"tickets whose status is New, Open, or Assigned"}},{"opcode":"SET_FIELD","operands":{"key":"ticket.status","text":"the ticket status to Overdue","value":"Overdue"}},{"opcode":"EFFECT","operands":{"text":"a public update"}},{"opcode":"EMIT_TRACE","operands":{"event":"TicketOverdue"}},{"opcode":"RETURN_SUCCESS","operands":{}}]}],"failures":[{"failure":"NotFound","traces":["TicketNotFound"]},{"failure":"PermissionDenied","traces":["InternalNotesDenied"]}]}
